# Spring Boot Settings
SPRING_DATASOURCE_URL=jdbc:mariadb://your-host:your-port/your-db?sslMode=trust
SPRING_DATASOURCE_USERNAME=your-username
SPRING_DATASOURCE_PASSWORD=your-password
SPRING_PROFILES_ACTIVE=dev

# JWT Settings
# Use a long random secret in real environments.
APP_SECURITY_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
APP_SECURITY_JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=900
APP_SECURITY_JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=604800
